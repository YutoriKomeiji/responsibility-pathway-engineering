{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YutoriKomeiji/responsibility-pathway-engineering/blob/main/schemas/external-kernel/action-request.schema.json",
  "title": "RPE External Kernel Action Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["request_id", "actor", "action", "target", "context", "evidence_scope"],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"type": "string", "enum": ["ai_agent", "human", "system"]},
        "id": {"type": "string", "minLength": 1}
      }
    },
    "action": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "context": {
      "type": "object",
      "additionalProperties": {"type": ["boolean", "string", "number", "null"]}
    },
    "evidence_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "missing"],
      "properties": {
        "available": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "missing": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  }
}
