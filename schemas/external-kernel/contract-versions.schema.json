{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YutoriKomeiji/responsibility-pathway-engineering/blob/main/schemas/external-kernel/contract-versions.schema.json",
  "title": "RPE External Kernel Contract Version Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "contracts", "reason_code_policy"],
  "properties": {
    "manifest_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_request", "gate_decision", "requirement_pack", "requirement_pack_governance"],
      "properties": {
        "action_request": {"$ref": "#/$defs/contract"},
        "gate_decision": {"$ref": "#/$defs/contract"},
        "requirement_pack": {"$ref": "#/$defs/contract"},
        "requirement_pack_governance": {"$ref": "#/$defs/contract"}
      }
    },
    "reason_code_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "unknown_code_behavior", "reuse_forbidden"],
      "properties": {
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "unknown_code_behavior": {"const": "preserve"},
        "reuse_forbidden": {"const": true}
      }
    }
  },
  "$defs": {
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "schema_path", "unknown_major_behavior"],
      "properties": {
        "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "schema_path": {"type": "string", "minLength": 1},
        "unknown_major_behavior": {"enum": ["reject", "human_gate"]},
        "notes": {"type": "string"}
      }
    }
  }
}
