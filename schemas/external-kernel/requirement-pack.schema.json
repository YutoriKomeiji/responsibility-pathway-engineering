{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YutoriKomeiji/responsibility-pathway-engineering/blob/main/schemas/external-kernel/requirement-pack.schema.json",
  "title": "RPE External Kernel Requirement Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "title",
    "version",
    "source_type",
    "source_metadata",
    "applies_when",
    "requirements",
    "decision_on_missing_requirement",
    "human_return",
    "reason_code_prefix"
  ],
  "properties": {
    "pack_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "source_type": {
      "type": "string",
      "enum": ["synthetic_demo", "organization_policy", "law_mapping", "standard_mapping", "guideline_mapping"]
    },
    "source_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_name",
        "source_url",
        "jurisdiction",
        "source_version",
        "effective_date",
        "review_owner",
        "review_status",
        "interpretation_status"
      ],
      "properties": {
        "authority_name": {"type": "string", "minLength": 1},
        "source_url": {"type": ["string", "null"], "format": "uri"},
        "jurisdiction": {"type": "string", "minLength": 1},
        "source_version": {"type": "string", "minLength": 1},
        "effective_date": {"type": ["string", "null"], "format": "date"},
        "review_owner": {"type": "string", "minLength": 1},
        "review_status": {"type": "string", "enum": ["synthetic", "unreviewed", "reviewed", "needs_update"]},
        "interpretation_status": {"type": "string", "enum": ["not_applicable", "draft_mapping", "reviewed_mapping"]}
      }
    },
    "applies_when": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {"action": {"type": "string", "minLength": 1}}
    },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
    },
    "decision_on_missing_requirement": {"type": "string", "enum": ["hold", "deny", "human_gate"]},
    "human_return": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {"role": {"type": "string", "minLength": 1}}
    },
    "reason_code_prefix": {"type": "string", "pattern": "^[A-Z0-9-]+$"},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
